# Binaries for programs and plugins
/intern
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# TODO file
todo.md

# Workiing Directory Files
**/build
**/traces

# Trace files
*.jsonl

# GoReleaser output
dist/

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Editor/IDE
# .idea/
# .vscode/
